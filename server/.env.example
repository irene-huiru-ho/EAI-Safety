# Copy this file to .env and fill in your values

# Google Drive service account credentials — path to the JSON file downloaded from Google Cloud Console
GOOGLE_CREDENTIALS_PATH=./google-credentials.json

# The Google Drive folder ID where study data will be stored
# Find this in the URL when you open the folder in Google Drive: drive.google.com/drive/folders/XXXXXXXXXXXXXXXXXXXXX
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-google-drive-folder-id

# Optional: if you store study data in a Shared Drive, set this to the Shared Drive ID
# You can find that ID in the Shared Drive URL: drive.google.com/drive/u/0/folders/SHARED_DRIVE_ID
GOOGLE_DRIVE_SHARED_DRIVE_ID=

# Password for the researcher dashboard
RESEARCHER_PASSWORD=change-me-before-deployment

# Port for the server (default 3001)
PORT=3003

# In production, set this to your deployed client URL
CLIENT_URL=http://localhost:5173
